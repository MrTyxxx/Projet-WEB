{% extends "monespace.html.twig" %}
{% block contenu_espace %}

<div class="container-fluid px-4">
  <h4 class="text-center mb-4 fw-bold">Créer une Offre de Stage</h4>

  <div class="border rounded-3 p-4">
    <form method="post" action="/espace/offres/creer">
      <div class="row g-3">

        <div class="col-md-12">
          <label class="form-label small">Titre de l'offre</label>
          <input type="text" name="titre_offre" class="form-control" required>
        </div>

        <div class="col-md-6">
          <label class="form-label small">Entreprise</label>
          <select name="id_entreprise" class="form-select">
            <option value="">-- Choisir --</option>
            <option value="1">Capgemini</option>
            <option value="2">Thales</option>
            <option value="3">Orange</option>
            <option value="4">Société Générale</option>
            <option value="5">Schneider Electric</option>
            <option value="6">Doctolib</option>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label small">Rémunération (€/mois)</label>
          <input type="number" name="remuneration" class="form-control" min="0">
        </div>

        <div class="col-md-6">
          <label class="form-label small">Nombre de places</label>
          <input type="number" name="nb_places" class="form-control" min="1">
        </div>

        <div class="col-md-6">
          <label class="form-label small">Date de l'offre</label>
          <input type="date" name="date_offre" class="form-control">
        </div>

        <div class="col-md-12">
          <label class="form-label small">Compétences requises</label>
          <div class="d-flex flex-wrap gap-2">
            {% set competences = ['PHP', 'Python', 'JavaScript', 'Java', 'SQL', 'React', 'Docker', 'Git'] %}
            {% for comp in competences %}
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="competences[]" value="{{ comp }}" id="comp_{{ comp }}">
                <label class="form-check-label small" for="comp_{{ comp }}">{{ comp }}</label>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="col-md-12">
          <label class="form-label small">Description</label>
          <textarea name="description" class="form-control" rows="4" required></textarea>
        </div>

        <div class="col-12 d-flex gap-2 mt-2">
          <button type="submit" class="btn btn-dark">Créer</button>
          <button type="reset" class="btn btn-outline-secondary">Réinitialiser</button>
          <a href="/espace/offres" class="btn btn-outline-danger ms-auto">Annuler</a>
        </div>

      </div>
    </form>
  </div>
</div>

{% endblock %}