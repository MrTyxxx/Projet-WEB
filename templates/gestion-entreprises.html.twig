{% extends "monespace.html.twig" %}
{% block contenu_espace %}

<div class="container-fluid px-2">

  <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <button class="btn btn-dark btn-sm">Toutes les Entreprises</button>

    <form method="GET" action="" class="d-flex gap-2 flex-wrap align-items-center">
      <input
        type="text"
        class="form-control form-control-sm w-auto"
        placeholder="Recherche par nom"
        name="nom"
        value="{{ searchNom }}"
      >

      <input
        type="text"
        class="form-control form-control-sm w-auto"
        placeholder="Recherche par secteur"
        name="secteur"
        value="{{ searchSecteur }}"
      >

      <button type="submit" class="btn btn-dark btn-sm">🔍 Rechercher</button>
    </form>

    <div class="ms-auto">
      <a href="/espace/entreprises/creer" class="btn btn-dark btn-sm">Ajouter une entreprise ➕</a>
    </div>
  </div>

  <div class="border rounded-3 p-3">
    <table class="table table-bordered table-sm text-center align-middle">
      <thead class="table-light">
        <tr>
          <th>N°</th>
          <th>Nom</th>
          <th>Secteur</th>
          <th>Campus</th>
          <th>E-mail</th>
          <th>Nb Offres liées</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {% for e in entreprises %}
          <tr>
            <td>{{ (page - 1) * 10 + loop.index }}</td>
            <td>{{ e.nom }}</td>
            <td>{{ e.secteur }}</td>
            <td>{{ e.campus ? e.campus.ville : 'Non défini' }}</td>
            <td>{{ e.email }}</td>
            <td>{{ e.nombreOffres }}</td>
            <td>
              {# tu pourras ajouter un vrai écran de modification plus tard #}
              <a href="/entreprise/{{ e.idEntreprise }}" class="btn btn-sm btn-outline-secondary me-1">Voir</a>

              <button type="button"
                      class="btn btn-sm btn-outline-danger"
                      onclick="confirmerSuppressionEntreprise({{ e.idEntreprise }})">✖</button>

              <form id="form-supprimer-entreprise-{{ e.idEntreprise }}"
                    action="/espace/entreprises/{{ e.idEntreprise }}/supprimer"
                    method="POST" style="display:none;"></form>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="7" class="text-muted">Aucune entreprise trouvée.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    {% if pages > 1 %}
      <div class="d-flex justify-content-center mt-4">
        <nav>
          <ul class="pagination pagination-sm">
            <li class="page-item {% if page == 1 %}disabled{% endif %}">
              <a class="page-link" href="?page={{ page - 1 }}&nom={{ searchNom }}&secteur={{ searchSecteur }}">&laquo;</a>
            </li>
            {% for p in 1..pages %}
              <li class="page-item {% if p == page %}active{% endif %}">
                <a class="page-link" href="?page={{ p }}&nom={{ searchNom }}&secteur={{ searchSecteur }}">{{ p }}</a>
              </li>
            {% endfor %}
            <li class="page-item {% if page == pages %}disabled{% endif %}">
              <a class="page-link" href="?page={{ page + 1 }}&nom={{ searchNom }}&secteur={{ searchSecteur }}">&raquo;</a>
            </li>
          </ul>
        </nav>
      </div>
    {% endif %}

  </div>
</div>

<script>
function confirmerSuppressionEntreprise(id) {
    if (confirm('Confirmer la suppression de cette entreprise ?')) {
        document.getElementById('form-supprimer-entreprise-' + id).submit();
    }
}
</script>

{% endblock %}