{% extends "monespace.html.twig" %}
{% block contenu_espace %}

<div class="container-fluid px-2">

  <div class="d-flex gap-2 mb-3 flex-wrap">
    <button class="btn btn-dark btn-sm">Toutes les Entreprises</button>
    <input type="text" class="form-control form-control-sm w-auto" placeholder="Recherche par Noms" id="searchNom">
    <select class="form-select form-select-sm w-auto" id="filterSecteur">
      <option value="">Secteurs</option>
      <option value="IT">IT</option>
      <option value="Finance">Finance</option>
      <option value="Industrie">Industrie</option>
      <option value="Santé">Santé</option>
      <option value="Télécoms">Télécoms</option>
      <option value="Aérospatiale">Aérospatiale</option>
    </select>
  </div>

  <div class="border rounded-3 p-3">
    <table class="table table-bordered table-sm text-center align-middle" id="tableEntreprises">
      <thead class="table-light">
        <tr>
          <th>N°</th>
          <th>Nom Entreprise</th>
          <th>Secteurs</th>
          <th>Campus</th>
          <th>E-mail</th>
          <th>Contact</th>
          <th>Nb Offres liées</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1</td><td>Capgemini</td><td>IT</td><td>Reims</td><td>contact@capgemini.fr</td><td>06 11 22 33 44</td><td>3</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
        <tr>
          <td>2</td><td>Thales</td><td>Aérospatiale</td><td>Strasbourg</td><td>contact@thales.fr</td><td>06 22 33 44 55</td><td>2</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
        <tr>
          <td>3</td><td>Orange</td><td>Télécoms</td><td>Reims</td><td>contact@orange.fr</td><td>06 33 44 55 66</td><td>4</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
        <tr>
          <td>4</td><td>Société Générale</td><td>Finance</td><td>Strasbourg</td><td>contact@sg.fr</td><td>06 44 55 66 77</td><td>2</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
        <tr>
          <td>5</td><td>Schneider Electric</td><td>Industrie</td><td>Reims</td><td>contact@schneider.fr</td><td>06 55 66 77 88</td><td>1</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
        <tr>
          <td>6</td><td>Doctolib</td><td>Santé</td><td>Strasbourg</td><td>contact@doctolib.fr</td><td>06 66 77 88 99</td><td>2</td>
          <td><a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a><a href="#" class="btn btn-sm btn-outline-danger">✖</a></td>
        </tr>
      </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-2">
      <button class="btn btn-outline-secondary btn-sm">Précédent</button>
      <a href="/espace/entreprises/creer" class="btn btn-dark btn-sm">➕</a>
      <button class="btn btn-outline-secondary btn-sm">Suivant</button>
    </div>
  </div>

</div>

<script>
  document.getElementById('searchNom').addEventListener('input', filtrer);
  document.getElementById('filterSecteur').addEventListener('change', filtrer);

  function filtrer() {
    const nom = document.getElementById('searchNom').value.toLowerCase();
    const secteur = document.getElementById('filterSecteur').value;
    document.querySelectorAll('#tableEntreprises tbody tr').forEach(tr => {
      const nomCell = tr.cells[1].textContent.toLowerCase();
      const secteurCell = tr.cells[2].textContent.trim();
      const matchNom = nomCell.includes(nom);
      const matchSecteur = secteur === '' || secteurCell === secteur;
      tr.style.display = matchNom && matchSecteur ? '' : 'none';
    });
  }
</script>

{% endblock %}