          <th>Promo(s) gérée(s)</th>
          <th>Contact</th>
          <th>Campus</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1</td>
          <td>Dupont Marie</td>
          <td>marie.dupont@yourjob.com</td>
          <td><span class="badge bg-secondary me-1">A1</span><span class="badge bg-secondary me-1">A2</span><span class="badge bg-secondary">A3</span></td>
          <td>06 10 20 30 40</td>
          <td>Reims</td>
          <td>
            <a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a>
            <a href="#" class="btn btn-sm btn-outline-danger">✖</a>
          </td>
        </tr>
        <tr>
          <td>2</td>
          <td>Renaud Pierre</td>
          <td>pierre.renaud@yourjob.com</td>
          <td><span class="badge bg-secondary me-1">A4</span><span class="badge bg-secondary">A5</span></td>
          <td>06 50 60 70 80</td>
          <td>Strasbourg</td>
          <td>
            <a href="#" class="btn btn-sm btn-outline-secondary me-1">✏️</a>
            <a href="#" class="btn btn-sm btn-outline-danger">✖</a>
          </td>
        </tr>
        <tr>
          <td>3</td>
          <td>Leclerc Sophie</td>
          <td>sophie.leclerc@yourjob.com</td>
