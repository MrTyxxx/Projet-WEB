{% extends "monespace.html.twig" %}
{% block contenu_espace %}

<div class="container-fluid px-4">
  <div class="d-flex align-items-center mb-4 gap-2">
    <a href="/espace/{{ type == 'pilote' ? 'pilotes' : 'etudiants' }}" 
       class="btn btn-sm btn-outline-secondary">← Retour</a>
    <h5 class="mb-0">
      {{ mode == 'modifier' ? 'Modifier' : 'Créer' }} un compte {{ type }}
    </h5>
  </div>

  <div class="border rounded-3 p-4" style="max-width: 600px;">
    <form method="POST">

      <div class="row mb-3">
        <div class="col">
          <label class="form-label">Nom</label>
          <input type="text" name="nom" class="form-control"
                 value="{{ mode == 'modifier' ? compte.nom : '' }}" required>
        </div>
        <div class="col">
          <label class="form-label">Prénom</label>
          <input type="text" name="prenom" class="form-control"
                 value="{{ mode == 'modifier' ? compte.prenom : '' }}" required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control"
               value="{{ mode == 'modifier' ? compte.email : '' }}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Téléphone</label>
        <input type="text" name="telephone" class="form-control"
               value="{{ mode == 'modifier' ? compte.telephone : '' }}" required>
      </div>

      <div class="mb-3">
        <label class="form-label">
          Mot de passe{% if mode == 'modifier' %} 
          <small class="text-muted">(laisser vide pour ne pas changer)</small>
          {% endif %}
        </label>
        <input type="password" name="motdepasse" class="form-control"
               {{ mode == 'creer' ? 'required' : '' }}>
      </div>

      <div class="mb-3">
        <label class="form-label">Campus</label>
        <select name="campus" class="form-select">
          <option value="">-- Aucun --</option>
          {% for c in campuses %}
            <option value="{{ c.idCampus }}"
              {{ mode == 'modifier' and compte.campus and compte.campus.idCampus == c.idCampus ? 'selected' : '' }}>
              {{ c.ville }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-dark btn-sm">
          {{ mode == 'modifier' ? 'Enregistrer' : 'Créer le compte' }}
        </button>
        <a href="/espace/{{ type == 'pilote' ? 'pilotes' : 'etudiants' }}" 
           class="btn btn-outline-secondary btn-sm">Annuler</a>
      </div>

    </form>
  </div>
</div>

{% endblock %}