{% extends "base.html.twig" %}
{% block contenu %}

<div class="container py-4">
  <div class="row border rounded p-3">
    
    <div class="col-md-3 d-flex flex-column align-items-center">
      <div class="border rounded p-2 mb-3 position-relative" style="width:180px; height:180px;">
        <button class="btn btn-sm position-absolute top-0 end-0">♡</button>
        <img src="..." alt="Logo" class="img-fluid"/>
      </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#pop-up-notes">Notes</button>
    </div>
    

<!-- pop up Bootstrap -->
    <div class="modal" id="pop-up-notes">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Donnez une note</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">

                    <h4>Votre note :</h4>

                    <!-- etoiles -->
                    <div class="rating" id="ratingStars">
                        <span data-value="1">&#9733;</span>
                        <span data-value="2">&#9733;</span>
                        <span data-value="3">&#9733;</span>
                        <span data-value="4">&#9733;</span>
                        <span data-value="5">&#9733;</span>
                    </div>

                    <p class="mt-3">Note choisie : <strong id="noteValue">0</strong>/5</p>

                </div>
                <div class="modal-footer">
                    <button class="btn btn-success">Valider</button>
                </div>

            </div>
        </div>
    </div>

    <!-- choisir la note -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
<script>
        const stars = document.querySelectorAll('#ratingStars span');
        const noteValue = document.getElementById('noteValue');

        stars.forEach(star => {
            star.addEventListener('click', () => {
                let val = star.getAttribute('data-value');
                noteValue.textContent = val;

                stars.forEach(s => s.classList.remove('selected'));

                for (let i = 0; i < val; i++) {
                    stars[i].classList.add('selected');
                }
            });
        });
    </script>

    <div class="col-md-9 border-start">
      <h5 class="mb-3">Titre de l'entreprise</h5>
      <p class="mb-5">Description longue de l'entreprise...</p>
      <h6 class="mb-3">Notes de l'entreprise</h6>
      <p class="mb-3">4.0/5.0</p>

    <div id="etoiles"></div>

    <script>
        // 🎯 Change la note ici (entre 0 et 5)
        let note = 4;

        let max = 5;
        let html = "";

        for (let i = 1; i <= max; i++) {
            if (i <= Math.floor(note)) {
                html += '<span class="star">&#9733;</span>'; // étoile pleine
            } else if (i - note < 1) {
                html += '<span class="star">&#9734;</span>'; // étoile vide (pour demi on pourrait faire mieux)
            } else {
                html += '<span class="star">&#9734;</span>'; // vide
            }
        }

        document.getElementById("etoiles").innerHTML = html;
    </script>
    </div>

  </div>
</div>

{% endblock %}