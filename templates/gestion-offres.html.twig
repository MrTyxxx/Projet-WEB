<script>
  document.getElementById('searchNom').addEventListener('input', filtrer);
  document.getElementById('filterCampus').addEventListener('change', filtrer);

  function filtrer() {
    const nom = document.getElementById('searchNom').value.toLowerCase();
    const campus = document.getElementById('filterCampus').value;
    document.querySelectorAll('#tableOffres tbody tr').forEach(tr => {
      const nomCell = tr.cells[1].textContent.toLowerCase();
      const campusCell = tr.cells[6].textContent.trim();
      const matchNom = nomCell.includes(nom);
      const matchCampus = campus === '' || campusCell === campus;
      tr.style.display = matchNom && matchCampus ? '' : 'none';
    });
  }
</script>

