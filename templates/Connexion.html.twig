{% extends "base.html.twig" %}
{% block contenu %}

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-4">
      <h2 class="text-center mb-4">Connexion</h2>

       {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
      {% endif %}

       <form method="post" action="/Connexion">
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" placeholder="email@example.com"/>
        </div>
        <div class="mb-3">
  <label class="form-label">Mot de passe</label>
  <div class="position-relative">
    <input type="password" name="password" id="password" class="form-control pe-5" placeholder="Mot de passe" required/>
    <span id="togglePassword" onclick="
      const i = document.getElementById('password');
      const s = document.getElementById('togglePassword');
      if (i.type === 'password') { i.type = 'text'; s.textContent = '🙈'; }
      else { i.type = 'password'; s.textContent = '👁️'; }
    " style="position:absolute; right:12px; top:50%; transform:translateY(-50%); cursor:pointer;">👁️</span>
  </div>
</div>
        <div class="mb-3">
          <div class="form-check">
            <input type="checkbox" class="form-check-input" id="remember"/>
            <label class="form-check-label" for="remember">Se souvenir de moi</label>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100">Se connecter</button>
      </form>
    </div>
  </div>
</div>

{% endblock %}