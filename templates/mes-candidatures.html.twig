{# templates/mescandidature.html.twig #}
{% extends "monespace.html.twig" %}

{% block contenu_espace %}
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Mes Candidatures (3)</h1>
  </div>

  {# 3 candidatures d’exemple statiques comme sur ta maquette #}
  {% for idx in [0,1,2] %}
    <article class="bg-white mb-3 p-3 p-md-4 rounded-3 border">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1">
          <div class="flex-shrink-0">
            <div class="bg-light border rounded-3 d-flex align-items-center justify-content-center"
                 style="width: 80px; height: 60px;">
              <span class="small text-muted">Logo</span>
            </div>
          </div>

          <div>
            <h2 class="h5 mb-1">Titre du Stage + durée du stage</h2>
            <p class="mb-1 small text-muted">Nom de l'entreprise</p>
            <p class="mb-2 small text-muted">
              Postulé le 17/02/2026 · Reims · 4 mois · 700 €/mois
            </p>
          </div>
        </div>

        <div class="text-md-end d-flex flex-column align-items-md-end gap-2">
          <span class="badge bg-success">Entretien</span>
          <button class="btn btn-primary btn-sm px-4">Voir l'offre</button>
        </div>
      </div>

      {# Frise de statut statique #}
      <div class="mt-3">
        <div class="d-flex align-items-center">
          {% set active_index = idx + 1 %}
          {% for step_index in 0..3 %}
            <div class="d-flex flex-column align-items-center flex-fill">
              <div class="rounded-circle {{ step_index <= active_index ? 'bg-success' : 'bg-secondary' }}"
                   style="width: 14px; height: 14px;"></div>
            </div>
            {% if step_index < 3 %}
              <div class="flex-fill border-top {{ step_index < active_index ? 'border-success' : 'border-secondary' }}"></div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="d-flex justify-content-between mt-1 small text-muted">
          <span>Envoyée</span>
          <span>En examen</span>
          <span>Entretien</span>
          <span>Décision</span>
        </div>
      </div>

      <div class="mt-3 d-flex justify-content-end">
        <button class="btn btn-sm btn-outline-danger">
          Retirer la candidature
        </button>
      </div>
    </article>
  {% endfor %}

  <nav class="mt-4 d-flex justify-content-center">
    <ul class="pagination pagination-sm mb-0">
      <li class="page-item active"><span class="page-link">1</span></li>
      <li class="page-item disabled"><span class="page-link">2</span></li>
      <li class="page-item disabled"><span class="page-link">3</span></li>
      <li class="page-item disabled"><span class="page-link">4</span></li>
      <li class="page-item disabled"><span class="page-link">…</span></li>
      <li class="page-item disabled"><span class="page-link">N</span></li>
    </ul>
  </nav>
{% endblock %}
