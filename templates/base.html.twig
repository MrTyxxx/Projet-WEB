<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Page d'acceuil</title>
    <link href=https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>
  <body class="d-flex flex-column min-vh-100">
   <header>
   <nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
  <span class="navbar-brand">
    <img src="/images/yourjob.png" alt="Logo" height="60" class="d-inline-block align-text-top">
</span>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#monMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="monMenu">
      <ul class="navbar-nav ">
      <li class="nav-item"><a class="nav-link" href="/">Acceuil</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Offres</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Entreprise</a></li>
      </ul>
      <div class="dropdown ms-auto">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          👤 Profil
        </button>
        <ul class="dropdown-menu dropdown-menu-end"> <li><h6 class="dropdown-header">Mon Compte</h6></li>
          <li><a class="dropdown-item" href="#">⚙️ Réglages</a></li>
          <li><a class="dropdown-item" href="#">🔔 Notifications</a></li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item text-danger" href="/Connexion">Connexion</a></li>
        </ul>
      </div>
    </div>
  </div>
</nav>
   </header>
   <main>
      {% block contenu %}{% endblock %}
   </main>
  <footer class="mt-auto border-top mt-4 py-3">
  <ul class="list-inline text-center mb-0">
    <li class="list-inline-item">
      <a href="/Mentions" class="text-muted text-decoration-none">Mentions Légales</a>
    </li>
    <li class="list-inline-item">
      <a href="/Contact" class="text-muted text-decoration-none">Support</a>
    </li>
  </ul>
</footer>
    <script src=https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>