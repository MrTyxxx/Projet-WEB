{% extends "monespace.html.twig" %}
{% block contenu_espace %}

<div class="container-fluid px-4">
  <h4 class="text-center mb-4 fw-bold">Créer une Entreprise</h4>

  <div class="border rounded-3 p-4">

    {% if error is defined %}
      <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    <form method="post" action="/espace/entreprises/creer">
      <div class="row g-3">

        <div class="col-md-6">
          <label class="form-label small">Nom de l'entreprise</label>
          <input
            type="text"
            name="nom_entreprise"
            class="form-control"
            value="{{ old.nom_entreprise|default('') }}"
            required
          >
        </div>

        <div class="col-md-6">
          <label class="form-label small">Secteur</label>
          <input
            type="text"
            name="secteur"
            class="form-control"
            value="{{ old.secteur|default('') }}"
            required
          >
        </div>

        <div class="col-md-6">
          <label class="form-label small">Campus</label>
          <select name="campus" class="form-select" required>
            <option value="">-- Choisir --</option>
            {% for c in campuses %}
              <option value="{{ c.idCampus }}" {% if old.campus|default('') == c.idCampus %}selected{% endif %}>
                {{ c.ville }} ({{ c.codePostal }})
              </option>
            {% endfor %}
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label small">E-mail</label>
          <input
            type="email"
            name="email_contact"
            class="form-control"
            value="{{ old.email_contact|default('') }}"
            required
          >
        </div>

        <div class="col-md-12">
          <label class="form-label small">Description</label>
          <textarea
            name="description"
            class="form-control"
            rows="4"
          >{{ old.description|default('') }}</textarea>
        </div>

        <div class="col-12 d-flex gap-2 mt-2">
          <button type="submit" class="btn btn-dark">Créer</button>
          <button type="reset" class="btn btn-outline-secondary">Réinitialiser</button>
          <a href="/espace/entreprises" class="btn btn-outline-danger ms-auto">Annuler</a>
        </div>

      </div>
    </form>
  </div>
</div>

{% endblock %}