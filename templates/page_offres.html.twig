{% extends "base.html.twig" %}
{% block contenu %}

<section class="bg-light py-5 text-center">
  <div class="container">
    <h1 class="fw-bold mb-3">Trouve ton stage idéal</h1>
    <p class="text-muted mb-4">Des centaines d'offres dans les meilleures entreprises</p>
    
    <form class="row justify-content-center g-2">
      <div class="col-auto">
        <input type="text" placeholder="Poste (ex: Développeur)" class="form-control">
      </div>
      <div class="col-auto">
        <input type="text" placeholder="Ville" class="form-control">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary px-4">Rechercher</button>
      </div>
    </form>
  </div>
</section>

<div class="container py-5">
  <h2 class="fw-bold mb-4 text-center">Offres disponibles</h2>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage Développeur Fullstack</h5>
          <h6 class="card-subtitle mb-3 text-muted">Capgemini • Paris</h6>
          <p class="card-text">Participez à la création d'applications web innovantes aux côtés d'une équipe experte dans un environnement agile.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage Développeur Front-End</h5>
          <h6 class="card-subtitle mb-3 text-muted">Google • Paris</h6>
          <p class="card-text">Rejoignez nos équipes pour concevoir des interfaces web performantes utilisées par des millions de personnes.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage Développeur Web</h5>
          <h6 class="card-subtitle mb-3 text-muted">Orange • Nancy</h6>
          <p class="card-text">Intégrez une équipe technique d'un opérateur majeur pour participer au développement de nouveaux services numériques.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage IT & Data</h5>
          <h6 class="card-subtitle mb-3 text-muted">Société Générale • Paris</h6>
          <p class="card-text">Stage orienté innovation. Participez au développement d'outils internes liés à la finance et à l'analyse de données.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage Ingénieur Logiciel</h5>
          <h6 class="card-subtitle mb-3 text-muted">Microsoft • Issy-les-Moulineaux</h6>
          <p class="card-text">Apportez vos compétences à un leader mondial de la tech. Stage centré sur les technologies cloud et l'intelligence artificielle.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title fw-bold">Stage Développeur Backend</h5>
          <h6 class="card-subtitle mb-3 text-muted">Doctolib • Nantes</h6>
          <p class="card-text">Participez à l'évolution d'un service de santé utilisé partout en Europe. Idéal pour apprendre dans une scale-up tech.</p>
          <a href="#" class="btn btn-outline-primary btn-sm">Voir l'offre</a>
        </div>
      </div>
    </div>

  </div>

  <nav class="mt-5" aria-label="Pagination des offres">
    <ul class="pagination justify-content-center">
      <li class="page-item disabled">
        <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Précédent</a>
      </li>
      <li class="page-item active"><a class="page-link" href="#">1</a></li>
      <li class="page-item"><a class="page-link" href="#">2</a></li>
      <li class="page-item"><a class="page-link" href="#">3</a></li>
      <li class="page-item">
        <a class="page-link" href="#">Suivant</a>
      </li>
    </ul>
  </nav>
